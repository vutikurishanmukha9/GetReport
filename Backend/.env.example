OPENAI_API_KEY=your_openai_api_key_here

# Optional: OpenRouter as primary LLM provider
# OPENROUTER_API_KEY=your_openrouter_key_here

# Security: API Key authentication (leave empty to disable in dev)
# API_KEY=your-secret-api-key-here

# Database: PostgreSQL connection string (leave empty for SQLite)
# DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# Redis: Use authenticated URL in production
# REDIS_URL=rediss://:your-redis-password@host:6379/0

# CORS: Comma-separated allowed origins (restrict in production)
# CORS_ORIGINS=https://your-domain.com

# Storage (local | db | s3)
# local: Saves files to disk (default).
# db: Stores files in DB as BLOB/BYTEA. Use on Render to share files between workers.
# s3: AWS S3 generic standard.
# STORAGE_TYPE=s3
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# AWS_BUCKET_NAME=getreport-uploads
